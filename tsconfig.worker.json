{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist/worker",
    "noEmit": false,
    "esModuleInterop": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "worker/**/*.ts",
    "src/lib/**/*.ts",
    "src/services/**/*.ts",
    "src/generated/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
