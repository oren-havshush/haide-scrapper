generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SiteStatus {
  ANALYZING
  REVIEW
  ACTIVE
  FAILED
  SKIPPED
}

enum ScrapeRunStatus {
  IN_PROGRESS
  COMPLETED
  PARTIAL
  FAILED
}

enum AnalysisMethod {
  PATTERN_MATCH
  CRAWL_CLASSIFY
  NETWORK_INTERCEPT
  AI_REFINE
}

enum JobStatus {
  PENDING
  VALID
  INVALID
  NEEDS_REVIEW
}

enum WorkerJobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum WorkerJobType {
  ANALYSIS
  SCRAPE
  POLICY_REVIEW
}

enum ScrapingPolicyStatus {
  NOT_CHECKED
  POLICY_NOT_FOUND
  NO_EXPLICIT_RESTRICTION
  RESTRICTED
  REQUIRES_WRITTEN_PERMISSION
  UNCLEAR_NEEDS_REVIEW
  CHECK_FAILED
}

model Site {
  id              String      @id @default(cuid())
  siteUrl         String      @unique
  companyName     String?
  status          SiteStatus  @default(ANALYZING)
  confidenceScore Float?
  fieldMappings   Json?
  pageFlow        Json?
  adminNote       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  analyzingAt     DateTime?
  reviewAt        DateTime?
  activeAt        DateTime?
  failedAt        DateTime?
  skippedAt       DateTime?

  jobs                 Job[]
  scrapeRuns           ScrapeRun[]
  analysisResults      AnalysisResult[]
  workerJobs           WorkerJob[]
  jobLocationOverrides JobLocationOverride[]
  policyReviews        ScrapingPolicyReview[]

  scrapingPolicyStatus    ScrapingPolicyStatus @default(NOT_CHECKED)
  scrapingPolicyCheckedAt DateTime?
}

model Job {
  id               String    @id @default(cuid())
  title            String
  description      String?
  requirements     String?
  location         String
  department       String?
  externalJobId    String?
  publishDate      String?
  ageBucket        String?
  applicationInfo  String?
  detailUrl        String?
  rawData          Json
  validationStatus String?
  siteId           String
  site             Site      @relation(fields: [siteId], references: [id])
  scrapeRunId      String
  scrapeRun        ScrapeRun @relation(fields: [scrapeRunId], references: [id])
  createdAt        DateTime  @default(now())

  @@index([siteId])
  @@index([scrapeRunId])
  @@index([ageBucket])
}

model ScrapeRun {
  id              String          @id @default(cuid())
  siteId          String
  site            Site            @relation(fields: [siteId], references: [id])
  status          ScrapeRunStatus @default(IN_PROGRESS)
  jobCount        Int             @default(0)
  totalJobs       Int?
  validJobs       Int?
  invalidJobs     Int?
  error           String?
  failureCategory String?
  createdAt       DateTime        @default(now())
  completedAt     DateTime?

  jobs Job[]

  @@index([siteId])
}

// Stores per-job manual location overrides keyed by (siteId, jobKey).
// jobKey = externalJobId ?? detailUrl — stable across re-scrapes.
// The worker re-applies these after every scrape run so manual edits persist.
model JobLocationOverride {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  jobKey    String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, jobKey])
  @@index([siteId])
}

model AnalysisResult {
  id                String         @id @default(cuid())
  siteId            String
  site              Site           @relation(fields: [siteId], references: [id])
  method            AnalysisMethod
  fieldMappings     Json
  confidenceScores  Json
  overallConfidence Float
  apiEndpoint       String?
  createdAt         DateTime       @default(now())

  @@index([siteId])
}

model WorkerJob {
  id          String          @id @default(cuid())
  siteId      String
  site        Site            @relation(fields: [siteId], references: [id])
  type        WorkerJobType
  status      WorkerJobStatus @default(PENDING)
  payload     Json?
  result      Json?
  error       String?
  attempts    Int             @default(0)
  createdAt   DateTime        @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  @@index([siteId])
  @@index([status, type])
}

model ScrapingPolicyReview {
  id                        String               @id @default(cuid())
  siteId                    String
  site                      Site                 @relation(fields: [siteId], references: [id], onDelete: Cascade)
  status                    ScrapingPolicyStatus
  isScrapingRestricted      Boolean?
  requiresWrittenPermission Boolean?
  confidence                Int?
  language                  String?
  shortReason               String?
  matchedTerms              String[]
  evidenceSnippets          Json?
  reviewedUrls              String[]
  discoveredUrls            String[]
  reviewedDocTypes          String[]
  cleanedText               String?
  llmResultJson             Json?
  pagesChecked              Int                  @default(0)
  searchFallbackUsed        Boolean              @default(false)
  reviewSource              String?
  robotsChecked             Boolean              @default(false)
  robotsDisallowsAll        Boolean?
  robotsRelevantRules       String[]
  errorMessage              String?
  nextReviewAt              DateTime?
  model                     String?
  createdAt                 DateTime             @default(now())

  @@index([siteId])
  @@index([status])
}
