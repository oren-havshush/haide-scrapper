# Run the worker locally from an IL IP, picking up jobs queued from
# the deployed Render UI. Copy to `.env.worker` and fill in the real values
# (NEVER commit the filled file — see .gitignore).
#
# Usage:
#   npx dotenv -e .env.worker -- npm run worker:dev
#
# or, if you don't want a separate file, just `export` these in your shell
# before running `npm run worker:dev`.

# External (public) DB URL from Render dashboard -> scrapnew-db -> Connections
DATABASE_URL="postgresql://USER:PASS@dpg-XXXX-a.frankfurt-postgres.render.com/scrapnew"

# Public web URL — worker emits SSE events here so the deployed dashboard
# updates in real time
NEXT_PUBLIC_APP_URL="https://scrapnew-web.onrender.com"

# Same token the deployed web service is using
API_TOKEN="haideScrapper"

# Israeli locale so anti-bot WAFs are happy
SCRAPE_LOCALE="he-IL"
SCRAPE_TIMEZONE="Asia/Jerusalem"
SCRAPE_ACCEPT_LANGUAGE="he-IL,he;q=0.9,en-US;q=0.8,en;q=0.7"

# Optional — enable AI refine for low-confidence sites
# OPENAI_API_KEY="sk-..."
