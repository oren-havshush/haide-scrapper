# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local
.env.worker

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# WXT extension build output
extension/.output/
extension/.wxt/

# Local Claude Code scrap onboarding token (do NOT commit)
.claude/scrap-token

# /addsite skill scratch directory — per-onboarding artifacts written by the skill
.scratch/

# Per-site scratch sub-buckets under sites/<name>/.scratch/ — see docs/sites-layout.md
sites/**/.scratch/

# Oversize artifacts that live under sites/<name>/ but are not worth committing
sites/**/*.png
sites/**/*.bin
sites/**/raw-*.json
sites/**/*-raw*.json
sites/**/*.pma

# Windows
Thumbs.db
*.log
